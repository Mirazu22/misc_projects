from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path
from typing import Optional, Sequence, Dict, List, Tuple, Union

import numpy as np
import pandas as pd

from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment, PatternFill
from openpyxl.formatting.rule import ColorScaleRule
from openpyxl.utils import get_column_letter


@dataclass
class ExportConfig:
    freeze_panes_cell: str = "B2"
    header_fill_hex: str = "1F4E79"
    header_font_color_hex: str = "FFFFFF"
    add_conditional_formatting: bool = True
    # symmetric scaling bound for signed rel errors: percentile of |rel_err|
    signed_scale_percentile: float = 95.0


def _validate_columns(df: pd.DataFrame, cols: Sequence[str], label: str) -> None:
    missing = [c for c in cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing {label} columns in df: {missing}")


def _autosize_columns(ws, max_width: int = 60) -> None:
    for col_idx in range(1, ws.max_column + 1):
        col_letter = get_column_letter(col_idx)
        max_len = 0
        for row_idx in range(1, ws.max_row + 1):
            v = ws.cell(row=row_idx, column=col_idx).value
            if v is None:
                continue
            s = str(v)
            max_len = max(max_len, len(s))
        ws.column_dimensions[col_letter].width = min(max_len + 2, max_width)


def _style_header(ws, header_fill_hex: str, header_font_color_hex: str) -> None:
    fill = PatternFill("solid", fgColor=header_fill_hex)
    font = Font(bold=True, color=header_font_color_hex)
    align = Alignment(horizontal="center", vertical="center", wrap_text=True)

    for cell in ws[1]:
        cell.fill = fill
        cell.font = font
        cell.alignment = align
    ws.row_dimensions[1].height = 22


def _add_filters(ws) -> None:
    ws.auto_filter.ref = ws.dimensions


def _apply_percent_format(ws, col_indices: List[int]) -> None:
    for col_idx in col_indices:
        for row in range(2, ws.max_row + 1):
            cell = ws.cell(row=row, column=col_idx)
            if isinstance(cell.value, (int, float)) and cell.value is not None:
                cell.number_format = "0.00%"


def _apply_float_format(ws, col_indices: List[int], fmt: str = "0.0000") -> None:
    for col_idx in col_indices:
        for row in range(2, ws.max_row + 1):
            cell = ws.cell(row=row, column=col_idx)
            if isinstance(cell.value, (int, float)) and cell.value is not None:
                cell.number_format = fmt


def _add_symmetric_zero_centered_scale(ws, col_idx: int, max_abs: float) -> None:
    """
    3-color scale: -max_abs (red) -> 0 (green) -> +max_abs (red)
    """
    if not np.isfinite(max_abs) or max_abs <= 0:
        return

    rule = ColorScaleRule(
        start_type="num",
        start_value=-max_abs,
        start_color="F8696B",  # red
        mid_type="num",
        mid_value=0,
        mid_color="63BE7B",  # green
        end_type="num",
        end_value=max_abs,
        end_color="F8696B",  # red
    )

    col_letter = get_column_letter(col_idx)
    rng = f"{col_letter}2:{col_letter}{ws.max_row}"
    ws.conditional_formatting.add(rng, rule)


def _rmse_log_series(f: pd.Series, y: pd.Series) -> float:
    """
    RMSE of log-level differences: sqrt(mean((log(f) - log(y))^2))
    Only computed where f>0, y>0, and both non-missing.
    Returns NaN if no valid rows.
    """
    f = pd.to_numeric(f, errors="coerce")
    y = pd.to_numeric(y, errors="coerce")
    mask = f.notna() & y.notna() & (f > 0) & (y > 0)
    if mask.sum() == 0:
        return float("nan")
    d = np.log(f[mask].astype(float)) - np.log(y[mask].astype(float))
    return float(np.sqrt(np.mean(np.square(d))))


def export_forecast_diagnostics_to_excel_v2(
    df: pd.DataFrame,
    output_path: Union[str, Path],
    *,
    id_col: str,
    year_col: str,
    year_id_col: str,
    empirical_col: str,
    forecast_cols: Sequence[str],
    dummy_cols: Sequence[str],
    fc_model_cols: Optional[Sequence[str]] = None,
    config: Optional[ExportConfig] = None,
) -> Tuple[Path, Dict[str, pd.DataFrame]]:
    """
    Implements:
      - data_with_errors reordered so error cols sit next to their model columns
      - compute signed and abs relative error; show signed, hide abs in data_with_errors
      - conditional formatting on signed rel errors:
          symmetric red-green-red centered at 0, bounds set by p-th percentile of |rel_err|
      - NO conditional formatting for abs columns (they're hidden)
      - summary_by_id: mean abs rel err, mean signed rel err, RMSE log for each model
      - summary_by_model: same metrics but ignoring id
      - boxplot creation removed
    """
    if config is None:
        config = ExportConfig()

    output_path = Path(output_path)

    use_fc_models = fc_model_cols is not None and len(fc_model_cols) > 0
    fc_model_cols = list(fc_model_cols) if use_fc_models else []
    forecast_cols = list(forecast_cols)
    dummy_cols = list(dummy_cols)

    # Validate
    _validate_columns(df, [id_col, year_col, year_id_col, empirical_col], "base required")
    _validate_columns(df, forecast_cols, "forecast")
    _validate_columns(df, dummy_cols, "dummy")
    if use_fc_models:
        _validate_columns(df, fc_model_cols, "fc_model")

    out = df.copy()

    # Compute rel errors for all model columns we care about
    model_cols_all: List[str] = forecast_cols + (fc_model_cols if use_fc_models else [])
    y = pd.to_numeric(out[empirical_col], errors="coerce").astype(float)

    rel_cols: Dict[str, str] = {}      # model -> signed rel err col name
    abs_rel_cols: Dict[str, str] = {}  # model -> abs rel err col name

    for m in model_cols_all:
        f = pd.to_numeric(out[m], errors="coerce").astype(float)
        rel_name = f"rel_err__{m}"
        abs_name = f"abs_rel_err__{m}"

        # Signed relative error; if y is NaN => NaN; empirical never 0 per your note
        out[rel_name] = (f - y) / y
        out[abs_name] = out[rel_name].abs()

        rel_cols[m] = rel_name
        abs_rel_cols[m] = abs_name

    # --------------------------
    # Reorder columns for data_with_errors
    # --------------------------
    id_cols = [id_col, year_col, year_id_col]
    base_prefix = [c for c in id_cols if c in out.columns]

    error_like = set(rel_cols.values()) | set(abs_rel_cols.values())
    model_set = set(model_cols_all)

    other_cols = [
        c for c in out.columns
        if c not in set(base_prefix) and c not in model_set and c not in error_like
    ]

    model_blocks: List[str] = []
    for m in model_cols_all:
        model_blocks.extend([m, rel_cols[m], abs_rel_cols[m]])

    out_data = out[base_prefix + other_cols + model_blocks].copy()

    # --------------------------
    # Summary_by_id
    # --------------------------
    grp = out.groupby(id_col, dropna=False)
    rows = []
    for gid, g in grp:
        row = {id_col: gid}
        y_g = g[empirical_col]
        for m in model_cols_all:
            row[f"mean_abs_rel_err__{m}"] = pd.to_numeric(g[abs_rel_cols[m]], errors="coerce").mean(skipna=True)
            row[f"mean_rel_err__{m}"] = pd.to_numeric(g[rel_cols[m]], errors="coerce").mean(skipna=True)
            row[f"rmse_log__{m}"] = _rmse_log_series(g[m], y_g)

        for d in dummy_cols:
            row[f"avg_usage__{d}"] = pd.to_numeric(g[d], errors="coerce").mean(skipna=True)
        row["avg_usage__all_models"] = (
            float(np.nanmean([row[f"avg_usage__{d}"] for d in dummy_cols])) if dummy_cols else float("nan")
        )
        rows.append(row)

    summary_by_id = pd.DataFrame(rows)

    # --------------------------
    # Summary_by_model (ignore id)
    # --------------------------
    model_summary_rows = []
    for m in model_cols_all:
        model_summary_rows.append(
            {
                "model": m,
                "mean_abs_rel_err": pd.to_numeric(out[abs_rel_cols[m]], errors="coerce").mean(skipna=True),
                "mean_rel_err": pd.to_numeric(out[rel_cols[m]], errors="coerce").mean(skipna=True),
                "rmse_log": _rmse_log_series(out[m], out[empirical_col]),
                "n_rel_err": int(pd.to_numeric(out[rel_cols[m]], errors="coerce").notna().sum()),
                "n_rmse_log": int(
                    (pd.to_numeric(out[m], errors="coerce").notna()
                     & pd.to_numeric(out[empirical_col], errors="coerce").notna()
                     & (pd.to_numeric(out[m], errors="coerce") > 0)
                     & (pd.to_numeric(out[empirical_col], errors="coerce") > 0)).sum()
                ),
            }
        )
    summary_by_model = pd.DataFrame(model_summary_rows)

    # --------------------------
    # Write Excel (no notes sheet)
    # --------------------------
    with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
        out_data.to_excel(writer, index=False, sheet_name="data_with_errors")
        summary_by_id.to_excel(writer, index=False, sheet_name="summary_by_id")
        summary_by_model.to_excel(writer, index=False, sheet_name="summary_by_model")

    # --------------------------
    # Post-formatting
    # --------------------------
    wb = load_workbook(output_path)

    for sheet_name in ["data_with_errors", "summary_by_id", "summary_by_model"]:
        ws = wb[sheet_name]
        _style_header(ws, config.header_fill_hex, config.header_font_color_hex)
        _add_filters(ws)
        ws.freeze_panes = config.freeze_panes_cell
        _autosize_columns(ws)

        for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
            for cell in row:
                cell.alignment = Alignment(vertical="top", wrap_text=False)

    # --- data_with_errors: format + symmetric conditional on signed rel errors, hide abs cols
    ws_data = wb["data_with_errors"]
    headers = [c.value for c in ws_data[1]]

    signed_idx = [i + 1 for i, h in enumerate(headers) if isinstance(h, str) and h.startswith("rel_err__")]
    abs_idx = [i + 1 for i, h in enumerate(headers) if isinstance(h, str) and h.startswith("abs_rel_err__")]

    # Percent formatting for both (abs hidden but still percent-formatted)
    _apply_percent_format(ws_data, signed_idx + abs_idx)

    if config.add_conditional_formatting:
        p = float(config.signed_scale_percentile)

        for col_idx in signed_idx:
            vals = []
            for r in range(2, ws_data.max_row + 1):
                v = ws_data.cell(row=r, column=col_idx).value
                if isinstance(v, (int, float)) and v is not None and np.isfinite(v):
                    vals.append(float(v))

            if len(vals) == 0:
                continue

            max_abs = float(np.nanpercentile(np.abs(vals), p))
            _add_symmetric_zero_centered_scale(ws_data, col_idx, max_abs=max_abs)

    # Hide abs columns (no coloring applied to them)
    for col_idx in abs_idx:
        ws_data.column_dimensions[get_column_letter(col_idx)].hidden = True

    # --- summary_by_id: percent formats for rel errors & dummy usage; float for rmse_log
    ws_sum_id = wb["summary_by_id"]
    sum_headers = [c.value for c in ws_sum_id[1]]

    pct_cols = []
    float_cols = []
    for i, h in enumerate(sum_headers):
        if not isinstance(h, str):
            continue
        if h.startswith("mean_abs_rel_err__") or h.startswith("mean_rel_err__") or h.startswith("avg_usage__"):
            pct_cols.append(i + 1)
        if h.startswith("rmse_log__"):
            float_cols.append(i + 1)

    _apply_percent_format(ws_sum_id, pct_cols)
    _apply_float_format(ws_sum_id, float_cols, fmt="0.0000")

    # --- summary_by_model: formats
    ws_sum_model = wb["summary_by_model"]
    sm_headers = [c.value for c in ws_sum_model[1]]

    sm_pct = []
    sm_float = []
    for i, h in enumerate(sm_headers):
        if h in {"mean_abs_rel_err", "mean_rel_err"}:
            sm_pct.append(i + 1)
        if h == "rmse_log":
            sm_float.append(i + 1)

    _apply_percent_format(ws_sum_model, sm_pct)
    _apply_float_format(ws_sum_model, sm_float, fmt="0.0000")

    wb.save(output_path)

    dfs_written = {
        "data_with_errors": out_data,
        "summary_by_id": summary_by_id,
        "summary_by_model": summary_by_model,
    }
    return output_path, dfs_written
