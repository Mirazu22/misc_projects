from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path
from typing import Optional, Sequence, Dict, List, Tuple, Union

import numpy as np
import pandas as pd

from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment, PatternFill
from openpyxl.formatting.rule import ColorScaleRule
from openpyxl.utils import get_column_letter


@dataclass
class ExportConfig:
    add_conditional_formatting: bool = True
    freeze_panes_cell: str = "B2"
    header_fill_hex: str = "1F4E79"
    header_font_color_hex: str = "FFFFFF"


def _validate_columns(df: pd.DataFrame, cols: Sequence[str], label: str) -> None:
    missing = [c for c in cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing {label} columns in df: {missing}")


def _autosize_columns(ws, max_width: int = 55) -> None:
    for col_idx in range(1, ws.max_column + 1):
        col_letter = get_column_letter(col_idx)
        max_len = 0
        for row_idx in range(1, ws.max_row + 1):
            v = ws.cell(row=row_idx, column=col_idx).value
            if v is None:
                continue
            max_len = max(max_len, len(str(v)))
        ws.column_dimensions[col_letter].width = min(max_len + 2, max_width)


def _style_header(ws, header_fill_hex: str, header_font_color_hex: str) -> None:
    fill = PatternFill("solid", fgColor=header_fill_hex)
    font = Font(bold=True, color=header_font_color_hex)
    align = Alignment(horizontal="center", vertical="center", wrap_text=True)

    for cell in ws[1]:
        cell.fill = fill
        cell.font = font
        cell.alignment = align
    ws.row_dimensions[1].height = 22


def _add_filters(ws) -> None:
    ws.auto_filter.ref = ws.dimensions


def _apply_percent_format(ws, col_indices: List[int]) -> None:
    for col_idx in col_indices:
        for row in range(2, ws.max_row + 1):
            cell = ws.cell(row=row, column=col_idx)
            if isinstance(cell.value, (int, float)) and cell.value is not None:
                cell.number_format = "0.00%"


def _add_conditional_formatting(ws, col_indices: List[int]) -> None:
    # Green (low) -> Yellow -> Red (high)
    rule = ColorScaleRule(
        start_type="percentile", start_value=10, start_color="63BE7B",
        mid_type="percentile", mid_value=50, mid_color="FFEB84",
        end_type="percentile", end_value=90, end_color="F8696B"
    )
    for col_idx in col_indices:
        col_letter = get_column_letter(col_idx)
        rng = f"{col_letter}2:{col_letter}{ws.max_row}"
        ws.conditional_formatting.add(rng, rule)


def export_forecast_diagnostics_to_excel(
    df: pd.DataFrame,
    output_path: Union[str, Path],
    *,
    id_col: str,
    year_col: str,
    year_id_col: str,
    empirical_col: str,
    forecast_cols: Sequence[str],
    dummy_cols: Sequence[str],
    fc_model_cols: Optional[Sequence[str]] = None,
    keep_original_order_for_other_cols: bool = True,
    config: Optional[ExportConfig] = None,
) -> Tuple[Path, Dict[str, pd.DataFrame]]:
    """
    Creates a formatted Excel report.

    Key features requested:
      - data_with_errors reordered: each method column immediately followed by its abs and signed rel errors
      - excludes notes sheet
      - adds overall averages across all rows for each method, incl polarity (signed error)
      - dummy NA ignored in averages

    Sheets:
      1) data_with_errors
      2) summary_by_id
      3) overall_method_diagnostics
      4) usage_overall
    """
    if config is None:
        config = ExportConfig()

    output_path = Path(output_path)
    use_fc_models = fc_model_cols is not None and len(fc_model_cols) > 0

    _validate_columns(df, [id_col, year_col, year_id_col, empirical_col], "base required")
    _validate_columns(df, list(forecast_cols), "forecast")
    _validate_columns(df, list(dummy_cols), "dummy")
    if use_fc_models:
        _validate_columns(df, list(fc_model_cols), "fc_model")

    out = df.copy()

    # empirical can be NaN (not observed yet). You said it is never 0.
    y = out[empirical_col].astype(float)

    def signed_rel_err(f: pd.Series) -> pd.Series:
        f = f.astype(float)
        return (f - y) / y

    def abs_rel_err(f: pd.Series) -> pd.Series:
        return signed_rel_err(f).abs()

    # ---- Create error cols
    # Naming: abs_rel_err__X and signed_rel_err__X
    abs_err_cols: List[str] = []
    signed_err_cols: List[str] = []

    def add_error_cols_for(method_col: str) -> Tuple[str, str]:
        abs_c = f"abs_rel_err__{method_col}"
        sgn_c = f"signed_rel_err__{method_col}"
        out[sgn_c] = signed_rel_err(out[method_col])
        out[abs_c] = out[sgn_c].abs()
        abs_err_cols.append(abs_c)
        signed_err_cols.append(sgn_c)
        return abs_c, sgn_c

    for c in forecast_cols:
        add_error_cols_for(c)

    if use_fc_models:
        for c in fc_model_cols:  # type: ignore[arg-type]
            add_error_cols_for(c)

    # ---- data_with_errors column ordering
    id_cols = [id_col, year_col, year_id_col]

    # "Other" original columns: keep them, but place method blocks (value + errors) as requested.
    method_cols = list(forecast_cols) + (list(fc_model_cols) if use_fc_models else [])

    # Start with identifiers
    ordered_cols: List[str] = [c for c in id_cols if c in out.columns]

    # Keep empirical early (right after ids) because it's the benchmark
    if empirical_col not in ordered_cols:
        ordered_cols.append(empirical_col)

    # Optionally keep the remaining original (non-method, non-error) columns before method blocks
    # Your schema includes dummies; I put dummies AFTER method blocks by default for readability.
    original_cols = list(df.columns)

    # define "non-block" original cols excluding ids, empirical, method cols, and dummies (handled later)
    excluded = set(ordered_cols) | set(method_cols) | set(dummy_cols)
    other_original = [c for c in original_cols if c not in excluded]

    if keep_original_order_for_other_cols:
        ordered_cols.extend(other_original)
    else:
        ordered_cols.extend(sorted(other_original))

    # Add method blocks: value + abs error + signed error
    for c in method_cols:
        abs_c = f"abs_rel_err__{c}"
        sgn_c = f"signed_rel_err__{c}"
        ordered_cols.extend([c, abs_c, sgn_c])

    # Add dummies at the end (still in original order)
    ordered_cols.extend([c for c in dummy_cols if c in out.columns])

    # There might be any remaining columns (unlikely) — append them safely
    remaining = [c for c in out.columns if c not in ordered_cols]
    ordered_cols.extend(remaining)

    out = out[ordered_cols]

    # ---- summary_by_id
    # Average absolute errors per id for each method (pooled forecasts + optionally fc_models)
    abs_cols_forecasts = [f"abs_rel_err__{c}" for c in forecast_cols]
    signed_cols_forecasts = [f"signed_rel_err__{c}" for c in forecast_cols]

    summary_by_id = (
        out.groupby(id_col, dropna=False)[abs_cols_forecasts + signed_cols_forecasts]
        .mean(numeric_only=True)
        .reset_index()
    )
    summary_by_id["avg_abs_rel_err__forecasts"] = summary_by_id[abs_cols_forecasts].mean(axis=1, skipna=True)
    summary_by_id["avg_signed_rel_err__forecasts"] = summary_by_id[signed_cols_forecasts].mean(axis=1, skipna=True)

    if use_fc_models:
        abs_cols_models = [f"abs_rel_err__{c}" for c in fc_model_cols]  # type: ignore[arg-type]
        signed_cols_models = [f"signed_rel_err__{c}" for c in fc_model_cols]  # type: ignore[arg-type]

        model_part = (
            out.groupby(id_col, dropna=False)[abs_cols_models + signed_cols_models]
            .mean(numeric_only=True)
            .reset_index()
        )
        model_part["avg_abs_rel_err__fc_models"] = model_part[abs_cols_models].mean(axis=1, skipna=True)
        model_part["avg_signed_rel_err__fc_models"] = model_part[signed_cols_models].mean(axis=1, skipna=True)

        summary_by_id = summary_by_id.merge(model_part, on=id_col, how="left")

    # Add dummy usage per id (NaNs ignored => default mean(skipna=True))
    dummies = out[list(dummy_cols)].copy()
    dummy_usage_by_id = (
        pd.concat([out[[id_col]], dummies], axis=1)
        .groupby(id_col, dropna=False)[list(dummy_cols)]
        .mean(numeric_only=True)
        .reset_index()
    )
    dummy_usage_by_id["avg_usage__all_models"] = dummy_usage_by_id[list(dummy_cols)].mean(axis=1, skipna=True)

    summary_by_id = summary_by_id.merge(dummy_usage_by_id, on=id_col, how="left")

    # ---- Overall method diagnostics across ALL rows (polarity etc.)
    # We compute per method: mean(abs rel err), mean(signed rel err), share overestimate, n
    records = []
    for c in method_cols:
        abs_c = f"abs_rel_err__{c}"
        sgn_c = f"signed_rel_err__{c}"
        s = out[sgn_c]
        a = out[abs_c]

        valid = s.notna() & a.notna()
        n = int(valid.sum())

        mean_abs = float(a[valid].mean()) if n > 0 else np.nan
        mean_signed = float(s[valid].mean()) if n > 0 else np.nan
        share_over = float((s[valid] > 0).mean()) if n > 0 else np.nan

        # simple direction label
        if n == 0 or pd.isna(mean_signed):
            direction = np.nan
        elif mean_signed > 0:
            direction = "overestimate"
        elif mean_signed < 0:
            direction = "underestimate"
        else:
            direction = "neutral"

        records.append(
            {
                "method": c,
                "method_type": "forecast" if c in forecast_cols else "fc_model",
                "n": n,
                "mean_abs_rel_err": mean_abs,
                "mean_signed_rel_err": mean_signed,
                "share_overestimate": share_over,
                "direction_by_mean_signed": direction,
            }
        )

    overall_method_diagnostics = pd.DataFrame(records)

    # ---- Usage overall
    usage_overall = (
        dummies.mean(numeric_only=True)  # skipna=True default
        .to_frame("avg_usage")
        .reset_index()
        .rename(columns={"index": "dummy"})
    )

    # ---- Write to Excel
    with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
        out.to_excel(writer, index=False, sheet_name="data_with_errors")
        summary_by_id.to_excel(writer, index=False, sheet_name="summary_by_id")
        overall_method_diagnostics.to_excel(writer, index=False, sheet_name="overall_method_diagnostics")
        usage_overall.to_excel(writer, index=False, sheet_name="usage_overall")

    # ---- Format with openpyxl
    wb = load_workbook(output_path)

    for sheet_name in ["data_with_errors", "summary_by_id", "overall_method_diagnostics", "usage_overall"]:
        ws = wb[sheet_name]
        _style_header(ws, config.header_fill_hex, config.header_font_color_hex)
        _add_filters(ws)
        ws.freeze_panes = config.freeze_panes_cell
        _autosize_columns(ws)

        for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
            for cell in row:
                cell.alignment = Alignment(vertical="top", wrap_text=False)

    # Percent formatting:
    # - data_with_errors: abs_rel_err__* and signed_rel_err__*
    ws_data = wb["data_with_errors"]
    data_headers = [c.value for c in ws_data[1]]
    data_pct_cols = [
        i + 1 for i, h in enumerate(data_headers)
        if isinstance(h, str) and (h.startswith("abs_rel_err__") or h.startswith("signed_rel_err__"))
    ]
    _apply_percent_format(ws_data, data_pct_cols)

    # Conditional formatting: only for ABS error cols (usually what you want heat-mapped)
    if config.add_conditional_formatting:
        abs_cols_idx = [
            i + 1 for i, h in enumerate(data_headers)
            if isinstance(h, str) and h.startswith("abs_rel_err__")
        ]
        if abs_cols_idx:
            _add_conditional_formatting(ws_data, abs_cols_idx)

    # summary_by_id: percent cols include abs/signed + avg_usage + dummies
    ws_sum = wb["summary_by_id"]
    sum_headers = [c.value for c in ws_sum[1]]
    sum_pct_cols = [
        i + 1 for i, h in enumerate(sum_headers)
        if isinstance(h, str) and (
            h.startswith("abs_rel_err__")
            or h.startswith("signed_rel_err__")
            or h.startswith("avg_abs_rel_err__")
            or h.startswith("avg_signed_rel_err__")
            or h.startswith("avg_usage__")
            or h in set(dummy_cols)
        )
    ]
    _apply_percent_format(ws_sum, sum_pct_cols)

    # overall_method_diagnostics: percent cols for the error metrics + share_overestimate
    ws_overall = wb["overall_method_diagnostics"]
    overall_headers = [c.value for c in ws_overall[1]]
    overall_pct_cols = []
    for name in ["mean_abs_rel_err", "mean_signed_rel_err", "share_overestimate"]:
        if name in overall_headers:
            overall_pct_cols.append(overall_headers.index(name) + 1)
    _apply_percent_format(ws_overall, overall_pct_cols)

    # usage_overall: avg_usage as percent
    ws_usage = wb["usage_overall"]
    usage_headers = [c.value for c in ws_usage[1]]
    if "avg_usage" in usage_headers:
        _apply_percent_format(ws_usage, [usage_headers.index("avg_usage") + 1])

    wb.save(output_path)

    return output_path, {
        "data_with_errors": out,
        "summary_by_id": summary_by_id,
        "overall_method_diagnostics": overall_method_diagnostics,
        "usage_overall": usage_overall,
    }
