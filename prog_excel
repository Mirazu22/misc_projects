from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path
from typing import Optional, Sequence, Dict, List, Tuple, Union

import numpy as np
import pandas as pd

from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment, PatternFill
from openpyxl.utils import get_column_letter
from openpyxl.formatting.rule import FormulaRule


@dataclass
class ExportConfig:
    # Excel aesthetics
    freeze_panes_cell: str = "B2"
    header_fill_hex: str = "1F4E79"
    header_font_color_hex: str = "FFFFFF"

    # Conditional formatting (3-tier based on abs(error) quantiles)
    add_abs_distance_formatting: bool = True
    # Quantiles for tiering (per error column)
    q_low: float = 0.33
    q_high: float = 0.66

    # Fills for conditional tiers (green/yellow/red)
    fill_good_hex: str = "63BE7B"
    fill_mid_hex: str = "FFEB84"
    fill_bad_hex: str = "F8696B"


def _validate_columns(df: pd.DataFrame, cols: Sequence[str], label: str) -> None:
    missing = [c for c in cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing {label} columns in df: {missing}")


def _autosize_columns(ws, max_width: int = 55) -> None:
    for col_idx in range(1, ws.max_column + 1):
        col_letter = get_column_letter(col_idx)
        max_len = 0
        for row_idx in range(1, ws.max_row + 1):
            v = ws.cell(row=row_idx, column=col_idx).value
            if v is None:
                continue
            s = str(v)
            max_len = max(max_len, len(s))
        ws.column_dimensions[col_letter].width = min(max_len + 2, max_width)


def _style_header(ws, header_fill_hex: str, header_font_color_hex: str) -> None:
    fill = PatternFill("solid", fgColor=header_fill_hex)
    font = Font(bold=True, color=header_font_color_hex)
    align = Alignment(horizontal="center", vertical="center", wrap_text=True)

    for cell in ws[1]:
        cell.fill = fill
        cell.font = font
        cell.alignment = align
    ws.row_dimensions[1].height = 22


def _add_filters(ws) -> None:
    ws.auto_filter.ref = ws.dimensions


def _apply_percent_format(ws, col_indices: List[int]) -> None:
    for col_idx in col_indices:
        for row in range(2, ws.max_row + 1):
            cell = ws.cell(row=row, column=col_idx)
            if isinstance(cell.value, (int, float)) and cell.value is not None:
                cell.number_format = "0.00%"


def _apply_float_format(ws, col_indices: List[int]) -> None:
    for col_idx in col_indices:
        for row in range(2, ws.max_row + 1):
            cell = ws.cell(row=row, column=col_idx)
            if isinstance(cell.value, (int, float)) and cell.value is not None:
                cell.number_format = "0.0000"


def _col_index_map(ws) -> Dict[str, int]:
    headers = [c.value for c in ws[1]]
    out: Dict[str, int] = {}
    for i, h in enumerate(headers):
        if isinstance(h, str):
            out[h] = i + 1
    return out


def _safe_rmse(x: pd.Series) -> float:
    x = x.astype(float)
    x = x.replace([np.inf, -np.inf], np.nan).dropna()
    if len(x) == 0:
        return np.nan
    return float(np.sqrt(np.mean(x**2)))


def _rmse_log_diff(f: pd.Series, y: pd.Series) -> pd.Series:
    """
    Row-wise log diff: log(f) - log(y), NaN if f<=0 or y<=0 or missing.
    """
    f = f.astype(float)
    y = y.astype(float)
    ok = (f > 0) & (y > 0) & f.notna() & y.notna()
    out = pd.Series(np.nan, index=f.index, dtype=float)
    out.loc[ok] = np.log(f.loc[ok]) - np.log(y.loc[ok])
    return out


def _apply_abs_distance_conditional_formatting(
    ws,
    col_idx: int,
    q_low: float,
    q_high: float,
    fill_good_hex: str,
    fill_mid_hex: str,
    fill_bad_hex: str,
) -> None:
    """
    Colors a column by ABS(cell) distance from 0 using 3 tiers.
    Thresholds are computed from ABS(values) quantiles.
    """
    # Collect numeric values from the column
    vals = []
    for row in range(2, ws.max_row + 1):
        v = ws.cell(row=row, column=col_idx).value
        if isinstance(v, (int, float)) and v is not None and np.isfinite(v):
            vals.append(abs(float(v)))

    if len(vals) < 5:
        return  # too few to compute meaningful quantiles

    low_thr = float(np.quantile(vals, q_low))
    high_thr = float(np.quantile(vals, q_high))

    col_letter = get_column_letter(col_idx)
    rng = f"{col_letter}2:{col_letter}{ws.max_row}"

    fill_good = PatternFill("solid", fgColor=fill_good_hex)
    fill_mid = PatternFill("solid", fgColor=fill_mid_hex)
    fill_bad = PatternFill("solid", fgColor=fill_bad_hex)

    # Formulas are evaluated relative to top-left of the range; use the first row cell address
    top_cell = f"{col_letter}2"

    # Worst tier: ABS(cell) > high_thr
    rule_bad = FormulaRule(
        formula=[f"ABS({top_cell})>{high_thr}"],
        fill=fill_bad
    )
    # Middle tier: low_thr < ABS(cell) <= high_thr
    rule_mid = FormulaRule(
        formula=[f"AND(ABS({top_cell})>{low_thr},ABS({top_cell})<={high_thr})"],
        fill=fill_mid
    )
    # Best tier: ABS(cell) <= low_thr
    rule_good = FormulaRule(
        formula=[f"ABS({top_cell})<={low_thr}"],
        fill=fill_good
    )

    ws.conditional_formatting.add(rng, rule_bad)
    ws.conditional_formatting.add(rng, rule_mid)
    ws.conditional_formatting.add(rng, rule_good)


def export_forecast_diagnostics_to_excel(
    df: pd.DataFrame,
    output_path: Union[str, Path],
    *,
    id_col: str,
    year_col: str,
    year_id_col: str,
    empirical_col: str,
    forecast_cols: Sequence[str],
    dummy_cols: Sequence[str],
    fc_model_cols: Optional[Sequence[str]] = None,
    config: Optional[ExportConfig] = None,
) -> Tuple[Path, Dict[str, pd.DataFrame]]:
    """
    Implements:
      - data_with_errors: signed relative errors next to each corresponding series
      - summary_by_id: mean abs rel err, mean signed rel err, RMSE(log(f)-log(y)) per id and series
      - summary_by_model: same metrics per series (ignoring id)
      - dummy usage (NA ignored) per id + overall

    Relative error (signed): (f - y) / y
    Absolute relative error used in summaries: abs((f - y) / y)
    """
    if config is None:
        config = ExportConfig()

    output_path = Path(output_path)
    use_fc_models = fc_model_cols is not None and len(fc_model_cols) > 0

    # Validate columns
    _validate_columns(df, [id_col, year_col, year_id_col, empirical_col], "base required")
    _validate_columns(df, list(forecast_cols), "forecast")
    _validate_columns(df, list(dummy_cols), "dummy")
    if use_fc_models:
        _validate_columns(df, list(fc_model_cols), "fc_model")

    out = df.copy()
    y = out[empirical_col].astype(float)

    # Series we compute diagnostics for
    series_cols: List[str] = list(forecast_cols) + (list(fc_model_cols) if use_fc_models else [])

    # Signed relative error columns for data sheet
    rel_err_cols: Dict[str, str] = {}  # series_col -> rel_err_col_name
    for c in series_cols:
        new_c = f"rel_err__{c}"
        out[new_c] = (out[c].astype(float) - y) / y  # signed
        rel_err_cols[c] = new_c

    # ---- Build data_with_errors column order: identifiers + [col, rel_err__col] pairs ----
    id_cols_ordered = [id_col, year_col, year_id_col]
    keep_first = [c for c in id_cols_ordered if c in out.columns]

    # Start with identifiers
    data_cols: List[str] = keep_first.copy()

    # Add empirical early (no error column)
    if empirical_col not in data_cols:
        data_cols.append(empirical_col)

    # Add forecast + error pairs
    for c in forecast_cols:
        if c not in data_cols:
            data_cols.append(c)
        rc = rel_err_cols[c]
        if rc not in data_cols:
            data_cols.append(rc)

    # Add dummies next (as they describe model usage)
    for c in dummy_cols:
        if c not in data_cols:
            data_cols.append(c)

    # Add fc_models + error pairs
    if use_fc_models:
        for c in fc_model_cols:  # type: ignore[arg-type]
            if c not in data_cols:
                data_cols.append(c)
            rc = rel_err_cols[c]
            if rc not in data_cols:
                data_cols.append(rc)

    # Finally, append any remaining columns not captured (keeps you safe if df has extras)
    remaining = [c for c in out.columns if c not in data_cols]
    data_cols.extend(remaining)

    out_data = out[data_cols]

    # ---- Summary metrics ----
    # Per-row absolute rel error for summaries
    abs_rel = {}
    for c in series_cols:
        abs_rel[c] = out[rel_err_cols[c]].abs()

    # Per-row log diff for RMSE logs
    log_diff = {}
    for c in series_cols:
        log_diff[c] = _rmse_log_diff(out[c], y)

    # ---- summary_by_id ----
    # mean signed rel error per id
    mean_rel_by_id = (
        out.groupby(id_col, dropna=False)[[rel_err_cols[c] for c in series_cols]]
        .mean(numeric_only=True)
        .reset_index()
    )
    mean_rel_by_id = mean_rel_by_id.rename(columns={rel_err_cols[c]: f"mean_rel_err__{c}" for c in series_cols})

    # mean abs rel error per id
    abs_rel_df = pd.DataFrame({f"mean_abs_rel_err__{c}": abs_rel[c] for c in series_cols})
    abs_rel_df[id_col] = out[id_col].values
    mean_abs_by_id = (
        abs_rel_df.groupby(id_col, dropna=False)[[f"mean_abs_rel_err__{c}" for c in series_cols]]
        .mean(numeric_only=True)
        .reset_index()
    )

    # RMSE log diff per id
    log_df = pd.DataFrame({f"logdiff__{c}": log_diff[c] for c in series_cols})
    log_df[id_col] = out[id_col].values

    rmse_log_by_id_rows = []
    for g, sub in log_df.groupby(id_col, dropna=False):
        row = {id_col: g}
        for c in series_cols:
            row[f"rmse_log__{c}"] = _safe_rmse(sub[f"logdiff__{c}"])
        rmse_log_by_id_rows.append(row)
    rmse_log_by_id = pd.DataFrame(rmse_log_by_id_rows)

    # Dummy usage per id (NA ignored automatically)
    dummy_usage_by_id = (
        out.groupby(id_col, dropna=False)[list(dummy_cols)]
        .mean(numeric_only=True)
        .reset_index()
    )
    dummy_usage_by_id["avg_usage__all_models"] = dummy_usage_by_id[list(dummy_cols)].mean(axis=1, skipna=True)

    summary_by_id = (
        mean_abs_by_id
        .merge(mean_rel_by_id, on=id_col, how="left")
        .merge(rmse_log_by_id, on=id_col, how="left")
        .merge(dummy_usage_by_id, on=id_col, how="left")
    )

    # ---- summary_by_model (ignore id) ----
    # one row per series column
    rows = []
    for c in series_cols:
        rel = out[rel_err_cols[c]].astype(float)
        absr = rel.abs()
        ld = log_diff[c]
        rows.append(
            {
                "model": c,
                "mean_abs_rel_err": float(absr.mean(skipna=True)),
                "mean_rel_err": float(rel.mean(skipna=True)),
                "rmse_log": _safe_rmse(ld),
                "n_rel_err": int(rel.notna().sum()),
                "n_log_rmse": int(pd.Series(ld).notna().sum()),
            }
        )
    summary_by_model = pd.DataFrame(rows)

    # ---- usage_overall ----
    usage_overall = (
        out[list(dummy_cols)]
        .mean(numeric_only=True)
        .to_frame("avg_usage")
        .reset_index()
        .rename(columns={"index": "dummy"})
    )

    # Write sheets (NO notes)
    with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
        out_data.to_excel(writer, index=False, sheet_name="data_with_errors")
        summary_by_id.to_excel(writer, index=False, sheet_name="summary_by_id")
        summary_by_model.to_excel(writer, index=False, sheet_name="summary_by_model")
        usage_overall.to_excel(writer, index=False, sheet_name="usage_overall")

    # ---- Excel formatting ----
    wb = load_workbook(output_path)
    sheet_names = ["data_with_errors", "summary_by_id", "summary_by_model", "usage_overall"]

    for sheet_name in sheet_names:
        ws = wb[sheet_name]
        _style_header(ws, config.header_fill_hex, config.header_font_color_hex)
        _add_filters(ws)
        ws.freeze_panes = config.freeze_panes_cell
        _autosize_columns(ws)

        for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
            for cell in row:
                cell.alignment = Alignment(vertical="top", wrap_text=False)

    # Formats + conditional formatting on data_with_errors error columns
    ws_data = wb["data_with_errors"]
    hdr_to_idx = _col_index_map(ws_data)

    # Signed relative error columns are percentages
    data_err_cols_idx = [hdr_to_idx[f"rel_err__{c}"] for c in series_cols if f"rel_err__{c}" in hdr_to_idx]
    _apply_percent_format(ws_data, data_err_cols_idx)

    if config.add_abs_distance_formatting:
        for col_idx in data_err_cols_idx:
            _apply_abs_distance_conditional_formatting(
                ws_data,
                col_idx=col_idx,
                q_low=config.q_low,
                q_high=config.q_high,
                fill_good_hex=config.fill_good_hex,
                fill_mid_hex=config.fill_mid_hex,
                fill_bad_hex=config.fill_bad_hex,
            )

    # summary_by_id: percent for mean_*rel_err*, float for rmse_log__
    ws_sum = wb["summary_by_id"]
    sum_hdr = _col_index_map(ws_sum)
    pct_cols = [idx for h, idx in sum_hdr.items() if h.startswith("mean_abs_rel_err__") or h.startswith("mean_rel_err__") or h in set(dummy_cols) or h == "avg_usage__all_models"]
    rmse_cols = [idx for h, idx in sum_hdr.items() if h.startswith("rmse_log__")]

    _apply_percent_format(ws_sum, pct_cols)
    _apply_float_format(ws_sum, rmse_cols)

    # summary_by_model: percent for mean_*rel_err, float for rmse_log
    ws_m = wb["summary_by_model"]
    m_hdr = _col_index_map(ws_m)
    m_pct_cols = [m_hdr[c] for c in ["mean_abs_rel_err", "mean_rel_err"] if c in m_hdr]
    m_float_cols = [m_hdr["rmse_log"]] if "rmse_log" in m_hdr else []
    _apply_percent_format(ws_m, m_pct_cols)
    _apply_float_format(ws_m, m_float_cols)

    # usage_overall: percent avg_usage
    ws_u = wb["usage_overall"]
    u_hdr = _col_index_map(ws_u)
    if "avg_usage" in u_hdr:
        _apply_percent_format(ws_u, [u_hdr["avg_usage"]])

    wb.save(output_path)

    return output_path, {
        "data_with_errors": out_data,
        "summary_by_id": summary_by_id,
        "summary_by_model": summary_by_model,
        "usage_overall": usage_overall,
    }
