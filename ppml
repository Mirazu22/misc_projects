# MAIN DRIVER
# ============================================================

def run_skill_flow_analysis(F, S, verbose=True):
    """
    Run the full workflow:

    1. Build a margins-only expected-flow benchmark.
    2. Compute an excess-flow diagnostic.
    3. Fit a PPML model with origin and destination fixed effects only.
    4. Fit a PPML model that adds skill similarity.
    5. Compare model fit.

    Parameters
    ----------
    F : array-like or sparse matrix
        Raw directed occupation-to-occupation flow matrix.
    S : array-like or sparse matrix
        Occupation similarity matrix of the same shape as F.
    verbose : bool, default True
        Whether to print IRLS iteration progress.

    Returns
    -------
    results : dict
        Dictionary containing benchmarks, diagnostics, fitted models, and fitted matrices.
    """
    F = to_dense_array(F)
    S = to_dense_array(S)

    if F.shape != S.shape:
        raise ValueError(f"F and S must have the same shape; got {F.shape} and {S.shape}.")
    if F.ndim != 2 or F.shape[0] != F.shape[1]:
        raise ValueError(f"F must be square; got shape {F.shape}.")
    if S.ndim != 2 or S.shape[0] != S.shape[1]:
        raise ValueError(f"S must be square; got shape {S.shape}.")
    if np.any(F < 0):
        raise ValueError("F contains negative flows, which are not allowed.")

    n = F.shape[0]
    offdiag_mask = ~np.eye(n, dtype=bool)

    # --------------------------------------------------------
    # Step 1: margins-only benchmark
    # --------------------------------------------------------
    E0, origin_totals, destination_totals, total_flow = margins_expected_flow(
        F, exclude_diagonal=True
    )

    print("=" * 72)
    print("STEP 1: MARGINS-ONLY BENCHMARK")
    print("=" * 72)
    print("This benchmark asks:")
    print("  What flows would we expect if mobility were driven only by")
    print("  origin outflow size and destination inflow size?")
    print("")
    print("Benchmark details:")
    print("  - diagonal/self-flows are excluded")
    print("  - expected flow formula is E0_ij = O_i * D_j / T")
    print("")
    print(f"Total off-diagonal flow T: {total_flow:,.0f}")
    print(f"Mean origin outflow: {origin_totals.mean():,.2f}")
    print(f"Mean destination inflow: {destination_totals.mean():,.2f}")
    print(f"Largest origin outflow: {origin_totals.max():,.0f}")
    print(f"Largest destination inflow: {destination_totals.max():,.0f}")

    # --------------------------------------------------------
    # Step 2: excess-flow diagnostic
    # --------------------------------------------------------
    excess_log_flow = np.full_like(F, np.nan, dtype=float)
    excess_log_flow[offdiag_mask] = np.log(
        (F[offdiag_mask] + _EPS) / (E0[offdiag_mask] + _EPS)
    )

    offdiag_excess = excess_log_flow[offdiag_mask]

    print("\n" + "=" * 72)
    print("STEP 2: EXCESS-FLOW DIAGNOSTIC")
    print("=" * 72)
    print("Diagnostic quantity:")
    print("  log( observed flow / expected flow under margins-only benchmark )")
    print("")
    print("Interpretation:")
    print("  > 0 : more flow than margins alone would predict")
    print("  = 0 : exactly in line with margins")
    print("  < 0 : less flow than margins alone would predict")
    print("")
    print("Off-diagonal summary:")
    print(f"  Mean excess-log-flow: {np.nanmean(offdiag_excess):.6f}")
    print(f"  Std. dev. of excess-log-flow: {np.nanstd(offdiag_excess):.6f}")

    # --------------------------------------------------------
    # Step 3: prepare dyads
    # --------------------------------------------------------
    y, sim, origin_ix, dest_ix, offdiag_mask_check = vectorize_offdiag(F, S)

    print("\n" + "=" * 72)
    print("STEP 3: PREPARE DIRECTED OCCUPATION PAIRS")
    print("=" * 72)
    print("We keep all directed off-diagonal pairs i -> j.")
    print(f"Number of occupations: {n}")
    print(f"Number of directed off-diagonal dyads: {len(y):,}")
    print(f"Number of zero-flow dyads: {(y == 0).sum():,}")
    print(f"Share of zero-flow dyads: {(y == 0).mean():.3f}")

    # --------------------------------------------------------
    # Step 4: margins-only PPML
    # --------------------------------------------------------
    print("\n" + "=" * 72)
    print("STEP 4: FIT PPML MODEL 0 (MARGINS ONLY)")
    print("=" * 72)
    print("Mean model:")
    print("  E[F_ij] = exp(alpha_i + delta_j)")
    print("This asks whether origin and destination margins alone explain flows.")

    X0 = build_design_matrix(
        origin_ix=origin_ix,
        dest_ix=dest_ix,
        sim=None,
        n_occ=n,
        include_similarity=False,
    )

    res0 = fit_ppml_irls(X0, y, beta_start=None, verbose=verbose)
    summarize_ppml_result("PPML Model 0: margins only", res0, y, include_similarity=False)

    # --------------------------------------------------------
    # Step 5: margins + similarity PPML
    # --------------------------------------------------------
    print("\n" + "=" * 72)
    print("STEP 5: FIT PPML MODEL 1 (MARGINS + SIMILARITY)")
    print("=" * 72)
    print("Mean model:")
    print("  E[F_ij] = exp(alpha_i + delta_j + beta * similarity_ij)")
    print("This asks whether similarity explains excess flow beyond margins.")

    X1 = build_design_matrix(
        origin_ix=origin_ix,
        dest_ix=dest_ix,
        sim=sim,
        n_occ=n,
        include_similarity=True,
    )

    # Warm-start from Model 0:
    # Model 0 columns are [intercept, origin FE, destination FE]
    # Model 1 columns are [intercept, similarity, origin FE, destination FE]
    beta_start_1 = np.zeros(X1.shape[1])
    beta_start_1[0] = res0["beta"][0]
    beta_start_1[2:] = res0["beta"][1:]

    res1 = fit_ppml_irls(X1, y, beta_start=beta_start_1, verbose=verbose)
    summarize_ppml_result("PPML Model 1: margins + similarity", res1, y, include_similarity=True)

    # --------------------------------------------------------
    # Step 6: compare fit
    # --------------------------------------------------------
    print("\n" + "=" * 72)
    print("STEP 6: MODEL COMPARISON")
    print("=" * 72)

    pr2_0 = pseudo_r2(y, res0["mu"])
    pr2_1 = pseudo_r2(y, res1["mu"])

    print("Pseudo-R² comparison:")
    print(f"  Model 0 (margins only):         {pr2_0:.6f}")
    print(f"  Model 1 (margins + similarity): {pr2_1:.6f}")
    print(f"  Gain from adding similarity:    {pr2_1 - pr2_0:.6f}")
    print("")
    print("Interpretation:")
    print("  This gain is the extra explanatory power of similarity after")
    print("  accounting for origin outflow intensity and destination attractiveness.")

    # Reconstruct fitted matrices for inspection
    fitted0 = np.full_like(F, np.nan, dtype=float)
    fitted1 = np.full_like(F, np.nan, dtype=float)
    fitted0[offdiag_mask_check] = res0["mu"]
    fitted1[offdiag_mask_check] = res1["mu"]

    return {
        "E0_margins_only": E0,
        "excess_log_flow": excess_log_flow,
        "origin_totals": origin_totals,
        "destination_totals": destination_totals,
        "ppml_model_0": res0,
        "ppml_model_1": res1,
        "fitted_model_0": fitted0,
        "fitted_model_1": fitted1,
    }


